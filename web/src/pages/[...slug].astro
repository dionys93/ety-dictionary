---
// web/src/pages/[...slug].astro

// --- IMPORTS ---
// Import the utility that scans your local file system to build the site's routes
import { getDictionaryPaths } from '../utils/dictionary.js';

// Import the two main layout components
import DirectoryView from '../components/DirectoryView.astro';
import ContentView from '../components/ContentView.astro';
import BookReader from '../components/BookReader.jsx';

// --- ROUTING LOGIC ---
// getStaticPaths() is a mandatory Astro function for dynamic routing (like [...slug]).
// It executes at build time, calling your dictionary utility to figure out exactly 
// which HTML pages need to be generated based on your local folders and markdown files.
export async function getStaticPaths() {
  return getDictionaryPaths();
}

// --- PROPS & PARAMS ---
// Extract the specific data for the current page being generated.
// These props are passed down from the array of objects returned by getDictionaryPaths() above.
const { 
  type, 
  title, 
  contents, 
  content, 
  ext, 
  isRoot, 
  bookPages 
} = Astro.props;

const { slug } = Astro.params;

// If the folder has book pages, we render the reader!
const isBookDir = type === 'directory' && bookPages && bookPages.length > 0;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <style>
      /* Base resets */
      body { margin: 0; padding: 0; font-family: sans-serif; }
      
      /* The Two-Pane CSS Grid */
      .split-layout {
        display: grid;
        grid-template-columns: 350px 1fr; /* 350px for nav, the rest for content */
        height: 100vh;
        width: 100vw;
        overflow: hidden; /* Lock the main window from scrolling */
      }

      /* Left Navigation Pane */
      .left-pane {
        background-color: #f9fafb;
        border-right: 1px solid #e5e7eb;
        overflow-y: scroll; /* Allow independent scrolling */
      }

      /* Right Content Pane */
      .right-pane {
        background-color: #ffffff;
        overflow-y: auto; /* Allow independent scrolling */
      }
    </style>
  </head>
  
  <body>
    <div class="split-layout">
      
      {/* --- LEFT PANE: NAVIGATION --- */}
      <nav class="left-pane">
        <DirectoryView 
          title={title} 
          items={contents} /* NOTE: This will break temporarily when viewing files until Step 2 */
          content={type === 'directory' ? content : undefined} 
          ext={ext} 
          isRoot={isRoot} 
          slug={slug || ''}
        />
      </nav>

      {/* --- RIGHT PANE: CONTENT --- */}
      <main class="right-pane">
        {isBookDir ? (
          /* Render the Interactive Flipbook! */
          <div style="padding: 2rem; display: flex; justify-content: center;">
            <BookReader pages={bookPages} client:load />
          </div>
        ) : content ? (
          /* Render file content OR directory index.md content */
          <ContentView 
            content={content} 
            ext={ext} 
            isRoot={isRoot} 
            slug={slug || ''} 
          />
        ) : (
          /* Placeholder when looking at a standard folder */
          <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #9ca3af;">
            Select a document from the left to read.
          </div>
        )}
      </main>

    </div>
  </body>
</html>