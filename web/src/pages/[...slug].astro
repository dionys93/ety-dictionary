---
// web/src/pages/[...slug].astro
import { getDictionaryPaths } from '../utils/dictionary.js';
import DirectoryView from '../components/DirectoryView.astro';
import ContentView from '../components/ContentView.astro';

export async function getStaticPaths() {
  return getDictionaryPaths();
}

const { type, title, contents, content, ext, isRoot } = Astro.props;
// Grab the current URL path (slug) from Astro
const { slug } = Astro.params;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body style="margin: 0; padding: 0; font-family: sans-serif;">
    
    {type === 'directory' ? (
      <DirectoryView 
        title={title} 
        items={contents} 
        content={content} 
        ext={ext} 
        isRoot={isRoot} 
        slug={slug || ''} 
      />
    ) : (
      <ContentView 
        content={content} 
        ext={ext} 
        isRoot={isRoot} 
        slug={slug || ''}
      />
    )}

  </body>
</html>