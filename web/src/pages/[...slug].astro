---
// web/src/pages/[...slug].astro

import { getDictionaryPaths } from '../utils/dictionary.js';
import Layout from '../layouts/Layout.astro';
import DirectoryView from '../components/DirectoryView.astro';
import ContentView from '../components/ContentView.astro';
import BookReader from '../components/BookReader.jsx';
import BackButton from '../components/ui/BackButton.astro';

export async function getStaticPaths() {
  return getDictionaryPaths();
}

const {
  type,
  title,
  contents,
  content,
  ext,
  isRoot,
  bookPages,
  view,
  widget,
} = Astro.props;

const isBookDir = type === 'directory' && bookPages && bookPages.length > 0;
const mobileMode = (type === 'file' || isBookDir) ? 'mobile-content' : 'mobile-nav';
---

<Layout title={title}>
  <style>
    .split-layout {
      display: grid;
      grid-template-columns: 350px 1fr;
      height: 100vh;
      width: 100vw;
      overflow: hidden;
    }

    .left-pane {
      background-color: #f9fafb;
      border-right: 1px solid #e5e7eb;
      overflow-y: auto;
    }

    .right-pane {
      background-color: #ffffff;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .mobile-back-nav {
      display: none;
    }

    @media (max-width: 768px) {
      .split-layout {
        display: block;
      }

      .split-layout.mobile-nav .right-pane {
        display: none;
      }
      .split-layout.mobile-nav .left-pane {
        height: 100vh;
      }

      .split-layout.mobile-content .left-pane {
        display: none;
      }
      .split-layout.mobile-content .right-pane {
        display: flex;
        height: 100vh;
      }

      .split-layout.mobile-content .mobile-back-nav {
        display: block;
        padding: 1rem;
        background-color: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        position: sticky;
        top: 0;
        z-index: 10;
      }
    }
  </style>

  <div class={`split-layout ${mobileMode}`}>
    <nav class="left-pane">
      <DirectoryView
        title={title}
        items={contents}
        content={type === 'directory' ? content : undefined}
        ext={ext}
        isRoot={isRoot}
        view={view}
      />
    </nav>

    <main class="right-pane">
      <div class="mobile-back-nav">
        <BackButton />
      </div>

      {isBookDir ? (
        <div style="padding: 2rem; display: flex; justify-content: center; flex-grow: 1;">
          <BookReader pages={bookPages} client:load />
        </div>
      ) : content ? (
        <ContentView
          content={content}
          ext={ext}
          isRoot={isRoot}
          widget={widget}
        />
      ) : (
        <div style="display: flex; align-items: center; justify-content: center; flex-grow: 1; color: #9ca3af;">
          Select a document from the left to read.
        </div>
      )}
    </main>
  </div>
</Layout>