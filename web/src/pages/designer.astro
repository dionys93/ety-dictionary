---
// web/src/pages/designer.astro
import Container from '../components/ui/Container.astro';
import Column from '../components/ui/Column.astro';

// Import the React designer component
import GlyphDesigner from '../components/GlyphDesigner.jsx';
---

<Container>
  <Column>
    <h1 style={{ marginBottom: '2rem' }}>Modular Glyph Designer</h1> 

    {/* Mount the interactive client component */}
    <GlyphDesigner client:load />

  </Column>
</Container>