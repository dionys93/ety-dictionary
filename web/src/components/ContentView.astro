---
// web/src/components/ContentView.astro

// --- IMPORTS ---
import { marked } from 'marked';
import Container from './ui/Container.astro';
import Column from './ui/Column.astro';
import BackButton from './ui/BackButton.astro';
import ScrollBar from './ui/ScrollBar.astro';
import VowelShiftVisualizer from './VowelShiftVisualizer.jsx';

// --- PROPS & STATE ---
const { content, ext, isRoot, slug } = Astro.props;

// --- DATA PROCESSING ---
const parsedContent = (ext === '.md' && content) ? marked.parse(content) : content;
---

<Container className="contentContainer">
    <Column className="contentColumn" style={{ width: '100%', maxWidth: '900px' }}>
        
        {/* --- MAIN CONTENT RENDERING --- */}
        {content && (
            <div style="width: 100%; margin-bottom: 2rem;">
                <ScrollBar>
                    {ext === '.md' ? (
                        <div class="markdown-body" set:html={parsedContent} />
                    ) : (
                        <pre style="white-space: pre-wrap; font-family: inherit;">{content}</pre>
                    )}
                </ScrollBar>
            </div>
        )}

        {/* --- CONDITIONAL FEATURE INJECTION --- */}
        {slug === 'orthography/phenomena/great-vowel-shift' && (
            <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
                <h3 style="font-size: 1.5rem; font-weight: bold; margin-bottom: 1rem; color: #1f2937;">
                    Interactive GVS Visualizer
                </h3>
                <VowelShiftVisualizer client:load />
            </div>
        )}

        {/* --- NAVIGATION --- */}
        {!isRoot && (
            <div style="margin-top: 2rem; align-self: flex-start;">
                <BackButton />
            </div>
        )}

    </Column>
</Container>

{/* --- GLOBAL STYLES FOR MARKDOWN RENDERER --- */}
<style is:global>
  .markdown-body table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
  }
  
  .markdown-body th, .markdown-body td {
    border: 1px solid #d1d5db; /* Clean, subtle gray border */
    padding: 10px 16px;
    text-align: left;
  }
  
  .markdown-body th {
    background-color: #f3f4f6;
    font-weight: 600;
  }

  /* Optional: Striping for easier reading on wide tables */
  .markdown-body tr:nth-child(even) {
    background-color: #f9fafb;
  }
</style>