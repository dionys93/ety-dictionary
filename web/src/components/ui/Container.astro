---
// web/src/components/ui/Container.astro
const { className = '', id, role } = Astro.props;
---

<div class={`container ${className}`} id={id} role={role}>
  <slot /> {/* Astro's equivalent of {children} */}
</div>

<style>
  /* You just drop your CSS module content right here */
  .container {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    padding: 20px;
    width: 100%;
    height: auto;
    box-sizing: border-box;
  }

  @media (max-width: 768px) { .container { padding: 15px; } }
  @media (max-width: 480px) { .container { padding: 10px; } }
</style>