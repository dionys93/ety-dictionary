---
// web/src/components/ui/GridList.astro
const { items } = Astro.props;
---

<ul class="grid-list">
  {items.map((item) => (
    <li class="grid-item">
      <a href={item.href} class="link">
        <span class="name">{item.name}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  /* Fluid Layout: Automatically wraps based on available space */
  .grid-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    /* This tells the grid: make items at least 110px wide. 
       If the sidebar is 350px, it fits 2 or 3. If it shrinks, it drops to 1. */
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: 1rem; 
    width: 100%;
  }
  
.grid-item {
    background-color: #f7f7f7;
    border: 1px solid #ddd;
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    transition: background-color 0.2s ease, transform 0.1s ease, box-shadow 0.2s ease;
    
    /* ADD THIS: Forces the grid item to strictly obey the grid column width */
    min-width: 0; 
  }
  
  .link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    text-decoration: none;
    color: #333;
    font-weight: 500;
    height: 100%;
    box-sizing: border-box;

    /* ADD THIS: Keeps the flex container from expanding past the grid item */
    overflow: hidden; 
  }

  /* ADD THIS NEW RULE: Truncates long dictionary terms gracefully with an ellipsis */
  .name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>